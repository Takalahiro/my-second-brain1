---
import '../styles/globals.css';
import ThemeBoot from '../components/ThemeBoot.astro';
import SiteNavBar from '../components/SiteNavBar.svelte';
import UiSkinInit from '../features/ui/components/UiSkinInit.svelte';

interface Props {
  title?: string;
  description?: string;
  fullWidth?: boolean;
  mathJax?: boolean;
}

const {
  title = 'My Second Brain',
  description = '工具',
  fullWidth = true,
  mathJax = false,
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth" data-font="wenkai" data-ui="mac">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="prefetch" href="/" as="document" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
    {mathJax && (
      <>
        <script is:inline>
          window.MathJax = {
            tex: {
              inlineMath: [['$', '$'], ['\\(', '\\)']],
              displayMath: [['$$', '$$'], ['\\[', '\\]']],
            },
            svg: { fontCache: 'global' },
            startup: { typeset: false },
          };
        </script>
        <script defer src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-svg.js"></script>
      </>
    )}
    <ThemeBoot />
    <script is:inline>
      (function () {
        var prefetched = false;
        function prefetchHome() {
          if (prefetched) return;
          prefetched = true;
          var link = document.createElement('link');
          link.rel = 'prefetch';
          link.href = '/';
          link.as = 'document';
          document.head.appendChild(link);
        }
        document.addEventListener('DOMContentLoaded', function () {
          var brand = document.querySelector('.site-nav-brand');
          if (brand) {
            brand.addEventListener('mouseenter', prefetchHome, { once: true });
            brand.addEventListener('focus', prefetchHome, { once: true });
          }
          if ('requestIdleCallback' in window) {
            requestIdleCallback(prefetchHome, { timeout: 4000 });
          }
        });
      })();
    </script>
  </head>
  <body class="min-h-screen transition-colors site-body tool-body">
    <SiteNavBar client:idle variant="tool" currentPath={Astro.url.pathname} />
    <UiSkinInit client:idle />
    <main class:list={['tool-main subpage-shell', fullWidth && 'tool-main--full']}>
      <div class:list={['tool-shell', fullWidth && 'tool-shell--flush']}>
        <slot />
      </div>
    </main>
  </body>
</html>

<style>
  .site-body,
  .tool-body {
    background: var(--bg, var(--bg-primary));
    color: var(--text, var(--text-primary));
    font-family: var(--font-body);
  }
  .tool-main {
    max-width: 72rem;
    margin: 0 auto;
    animation: site-main-in 0.35s var(--motion-ease) both;
  }
  .tool-main--full {
    max-width: none;
  }
  @keyframes site-main-in {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
