---
import '../styles/globals.css';
import SiteNavBar from '../components/SiteNavBar.astro';

interface Props {
  title?: string;
  description?: string;
  /** 是否全宽铺满（工具页默认 true） */
  fullWidth?: boolean;
}

const {
  title = 'My Second Brain',
  description = '工具',
  fullWidth = true,
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth" data-font="wenkai">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="prefetch" href="/" as="document" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
      const font = localStorage.getItem('second-brain:font-family');
      if (font && ['wenkai', 'inter', 'serif', 'plex', 'jp-pixel'].includes(font)) {
        document.documentElement.setAttribute('data-font', font);
      }
    </script>
    <script is:inline>
      (function () {
        var prefetched = false;
        function prefetchHome() {
          if (prefetched) return;
          prefetched = true;
          var link = document.createElement('link');
          link.rel = 'prefetch';
          link.href = '/';
          link.as = 'document';
          document.head.appendChild(link);
        }
        document.addEventListener('DOMContentLoaded', function () {
          var brand = document.querySelector('.site-nav-brand');
          if (brand) {
            brand.addEventListener('mouseenter', prefetchHome, { once: true });
            brand.addEventListener('focus', prefetchHome, { once: true });
          }
          if ('requestIdleCallback' in window) {
            requestIdleCallback(prefetchHome, { timeout: 4000 });
          }
        });
      })();
    </script>
  </head>
  <body class="min-h-screen transition-colors tool-body">
    <SiteNavBar variant="tool" currentPath={Astro.url.pathname} />
    <main class:list={['tool-main', fullWidth && 'tool-main--full']}>
      <slot />
    </main>
  </body>
</html>

<style>
  .tool-body {
    background: var(--bg-primary);
  }
  .tool-main {
    max-width: 72rem;
    margin: 0 auto;
    padding: 1rem 1rem 2rem;
    animation: site-main-in 0.35s var(--motion-ease) both;
  }
  .tool-main--full {
    max-width: none;
    padding: 0;
    min-height: calc(100vh - 80px);
  }
  @keyframes site-main-in {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
