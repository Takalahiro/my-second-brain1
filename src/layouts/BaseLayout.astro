---
import '../styles/globals.css';
import ThemeToggle from '../components/ThemeToggle.svelte';
import FontSwitcher from '../components/FontSwitcher.svelte';
import SiteNavBar from '../components/SiteNavBar.svelte';
import Mermaid from '../components/Mermaid.svelte';
import MobileViewModeToggle from '../components/MobileViewModeToggle.svelte';
import NotesToolHost from '../components/widgets/NotesToolHost.svelte';
import UiSkinInit from '../features/ui/components/UiSkinInit.svelte';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'My Second Brain',
  description = '我的第二大脑',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth" data-font="wenkai" data-ui="mac">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
      integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV"
      crossorigin="anonymous"
    />

    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }

      const font = localStorage.getItem('second-brain:font-family');
      if (font && ['wenkai', 'inter', 'serif', 'plex', 'jp-pixel'].includes(font)) {
        document.documentElement.setAttribute('data-font', font);
      }

      const notesMode = localStorage.getItem('second-brain:notes-display-mode');
      if (notesMode === 'widgets' || notesMode === 'recursive') {
        document.documentElement.setAttribute('data-notes-mode', notesMode);
      }

      const loc = localStorage.getItem('second-brain:locale');
      if (loc === 'en') {
        document.documentElement.lang = 'en';
        document.documentElement.dataset.locale = 'en';
      }

      const ui = localStorage.getItem('second-brain:ui-skin');
      if (ui) document.documentElement.setAttribute('data-ui', ui);
      if (localStorage.getItem('second-brain:ui-debug') === '1') {
        document.documentElement.classList.add('ui-debug', 'debug');
      }
    </script>
  </head>
  <body class="min-h-screen transition-colors site-body">
    <SiteNavBar client:load variant="site" currentPath={Astro.url.pathname} />
    <main class="site-main max-w-5xl mx-auto px-4 py-8">
      <slot />
    </main>

    <Mermaid client:idle />
    <MobileViewModeToggle client:load />
    <UiSkinInit client:load />
    <NotesToolHost client:only="svelte" />
  </body>
</html>

<style>
  .site-body {
    background: var(--bg-primary);
    color: var(--text-primary);
  }
  .site-main {
    animation: site-main-in 0.35s var(--motion-ease) both;
  }
  @keyframes site-main-in {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
