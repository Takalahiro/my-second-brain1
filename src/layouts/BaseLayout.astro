---
import '../styles/globals.css';
import ThemeToggle from '../components/ThemeToggle.svelte';
import FontSwitcher from '../components/FontSwitcher.svelte';
import Mermaid from '../components/Mermaid.svelte';
import MobileViewModeToggle from '../components/MobileViewModeToggle.svelte';
import NoteSearch from '../components/NoteSearch.svelte';
import NotesToolHost from '../components/widgets/NotesToolHost.svelte';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'My Second Brain',
  description = '我的第二大脑',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth" data-font="wenkai">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
      integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV"
      crossorigin="anonymous"
    />

    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }

      const font = localStorage.getItem('second-brain:font-family');
      if (font && ['wenkai', 'inter', 'serif', 'plex', 'jp-pixel'].includes(font)) {
        document.documentElement.setAttribute('data-font', font);
      }

      // 预水合：把 notes 折叠模式写到 <html> 上，让 client-only 组件初次渲染就用对状态。
      const notesMode = localStorage.getItem('second-brain:notes-display-mode');
      if (notesMode === 'widgets' || notesMode === 'recursive') {
        document.documentElement.setAttribute('data-notes-mode', notesMode);
      }
    </script>
  </head>
  <body class="min-h-screen transition-colors">
    <header class="site-header">
      <nav class="pixel-card glass-container nav-shell max-w-5xl mx-auto" aria-label="站点导航">
        <div class="nav-primary">
          <a href="/" class="nav-brand" aria-label="首页">🧠</a>
          <a href="/notes" class="nav-crumb" aria-label="去往笔记">
            <span class="nav-crumb-icon" aria-hidden="true">📚</span>
            <span class="nav-crumb-text">笔记</span>
          </a>
          <div class="nav-search">
            <NoteSearch client:load />
          </div>
          <div class="nav-actions">
            <FontSwitcher client:load />
            <ThemeToggle client:load />
          </div>
        </div>
        <div class="nav-secondary">
          <div class="nav-tools" aria-label="工具">
            <a href="/python" class="pixel-button nav-link" title="Python">Python</a>
            <a href="/matlab" class="pixel-button nav-link" title="MATLAB">MATLAB</a>
            <a href="/whiteboard" class="pixel-button nav-link" title="白板">白板</a>
            <a href="/graph" class="pixel-button nav-link" title="关系图谱">图谱</a>
          </div>
        </div>
      </nav>
    </header>
    <main class="max-w-5xl mx-auto px-4 py-8">
      <slot />
    </main>

    <!--
      client:idle 让浏览器在空闲帧才 hydrate Mermaid，
      避免首屏 JS 主线程被立即占用（这是「巨卡」的主要来源之一）。
      Mermaid 渲染本身还有 IntersectionObserver 懒加载，所以延迟挂载完全安全。
    -->
    <Mermaid client:idle />
    <MobileViewModeToggle client:load />
    <NotesToolHost client:only="svelte" />
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: max(env(safe-area-inset-top, 0px), 10px) 10px 0;
  }
  .nav-shell {
    border-width: 1px;
    padding: 10px 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .nav-primary {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
  }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
    margin-left: auto;
  }
  .nav-secondary {
    display: flex;
    min-width: 0;
  }
  .nav-brand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-button);
    text-decoration: none;
    font-size: 1.2rem;
    background: var(--bg-secondary);
    box-shadow: var(--shadow-pixel);
    border: 1px solid var(--border-color);
    flex-shrink: 0;
  }
  .nav-link {
    text-decoration: none;
    font-size: 0.875rem;
    padding: 6px 12px;
  }
  .nav-search {
    flex: 1;
    max-width: 420px;
    min-width: 0;
  }
  .nav-crumb {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: var(--text-primary);
    font-size: 0.84rem;
    font-weight: 600;
    padding: 6px 12px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-button);
    box-shadow: var(--shadow-pixel);
    transition: background 0.15s ease, transform 0.15s ease, border-color 0.15s ease;
    position: relative;
    flex-shrink: 0;
  }
  .nav-crumb::before {
    content: '/';
    position: absolute;
    left: -10px;
    color: var(--text-secondary);
    font-weight: 400;
    pointer-events: none;
  }
  .nav-crumb:hover {
    background: var(--bg-primary);
    transform: translateY(-1px);
    border-color: rgba(180, 140, 255, 0.4);
  }
  .nav-crumb-icon { font-size: 0.95rem; }

  .nav-tools {
    display: flex;
    flex-wrap: nowrap;
    gap: 6px;
    align-items: center;
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 2px;
  }
  .nav-tools::-webkit-scrollbar { display: none; }
  .nav-tools .nav-link {
    font-size: 0.75rem;
    padding: 5px 9px;
    flex-shrink: 0;
    white-space: nowrap;
  }

  @media (min-width: 769px) {
    .site-header {
      padding-left: 12px;
      padding-right: 12px;
    }
    .nav-shell {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      padding: 12px 16px;
      gap: 10px;
    }
    .nav-primary {
      flex: 1 1 320px;
    }
    .nav-secondary {
      flex: 1 1 auto;
      justify-content: flex-end;
    }
    .nav-tools {
      flex-wrap: wrap;
      overflow: visible;
      width: auto;
      justify-content: flex-end;
    }
  }

  @media (max-width: 768px) {
    .nav-crumb-text { display: none; }
    .nav-crumb { padding: 6px 8px; }
    .nav-crumb::before { display: none; }
    .nav-search { max-width: none; }
    .nav-tools .nav-link {
      padding: 6px 10px;
      font-size: 0.72rem;
    }
  }
</style>
