---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.svelte';
import Mermaid from '../components/Mermaid.svelte';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'My Second Brain', description = '我的第二大脑' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
      integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV"
      crossorigin="anonymous"
    />

    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="min-h-screen bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100 transition-colors">
    <header class="border-b border-gray-200 dark:border-gray-800 sticky top-0 bg-white/80 dark:bg-gray-950/80 backdrop-blur z-10">
      <nav class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="font-bold text-lg" aria-label="首页">🧠</a>
        <div class="flex items-center gap-4 text-sm">
          <a href="/notes" class="hover:underline">笔记</a>
          <a href="/tags" class="hover:underline">标签</a>
          <ThemeToggle client:load />
        </div>
      </nav>
    </header>
    <main class="max-w-5xl mx-auto px-4 py-8">
      <slot />
    </main>

    <!--
      client:idle 让浏览器在空闲帧才 hydrate Mermaid，
      避免首屏 JS 主线程被立即占用（这是「巨卡」的主要来源之一）。
      Mermaid 渲染本身还有 IntersectionObserver 懒加载，所以延迟挂载完全安全。
    -->
    <Mermaid client:idle />
  </body>
</html>
