---
import '../styles/globals.css';
import DesktopIntroSplash from '../components/desktop/DesktopIntroSplash.astro';
import HudEclipseIntro from '../components/desktop/HudEclipseIntro.astro';
import UiSkinInit from '../features/ui/components/UiSkinInit.svelte';

interface Props {
  title?: string;
  description?: string;
  // 主界面首次访问时的启动动画
  introSplash?: boolean;
}

const {
  title = 'My Second Brain · 桌面',
  description = 'macOS 风格桌面',
  introSplash = false,
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth" data-font="wenkai" data-ui="mac">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
        document.documentElement.setAttribute('data-theme', 'light');
      } else if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
        document.documentElement.setAttribute('data-theme', 'dark');
      }
      const font = localStorage.getItem('second-brain:font-family');
      if (font && ['wenkai', 'inter', 'serif', 'plex', 'jp-pixel'].includes(font)) {
        document.documentElement.setAttribute('data-font', font);
      }
      const loc = localStorage.getItem('second-brain:locale');
      if (loc === 'en') {
        document.documentElement.lang = 'en';
        document.documentElement.dataset.locale = 'en';
      }
      const ui = localStorage.getItem('second-brain:ui-skin');
      if (ui) document.documentElement.setAttribute('data-ui', ui);
      if (localStorage.getItem('second-brain:ui-debug') === '1') {
        document.documentElement.classList.add('ui-debug', 'debug');
      }
    </script>
    {introSplash && (
      <script is:inline>
        var ui = localStorage.getItem('second-brain:ui-skin');
        if (ui === 'hud') {
          document.documentElement.classList.add('hud-eclipse-intro-active');
        } else if (!localStorage.getItem('second-brain:desktop-intro-v1')) {
          document.documentElement.classList.add('desktop-intro-active');
        }
      </script>
    )}
  </head>
  <body class="mac-os-body">
    {introSplash && <HudEclipseIntro />}
    {introSplash && <DesktopIntroSplash />}
    <UiSkinInit client:load />
    <slot />
  </body>
</html>

<style is:global>
  .mac-os-body {
    margin: 0;
    overflow: hidden;
    height: 100dvh;
    width: 100vw;
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: var(--font-body-current), -apple-system, BlinkMacSystemFont, 'PingFang SC', system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    transition: background-color var(--motion-base) var(--motion-ease),
      color var(--motion-base) var(--motion-ease);
  }
</style>
