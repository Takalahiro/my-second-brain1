---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 4);
---

{tocHeadings.length > 0 && (
  <nav class="text-sm">
    <h2 class="font-semibold text-gray-500 dark:text-gray-400 uppercase text-xs mb-3 tracking-wider">
      目录
    </h2>
    <ul class="space-y-2 border-l border-gray-200 dark:border-gray-800">
      {tocHeadings.map((h) => (
        <li
          class="pl-3 hover:border-blue-500 border-l-2 border-transparent -ml-px transition"
          style={`margin-left: ${(h.depth - 2) * 12}px`}
        >
          <a href={`#${h.slug}`} class="text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 block py-0.5">
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
