---
import NoteOutlineHost from './NoteOutlineHost.svelte';
import type { MarkdownHeading } from 'astro';

interface BacklinkItem {
  title: string;
  href: string;
}
interface Props {
  title: string;
  tags?: string[];
  headings?: MarkdownHeading[];
  backlinks?: BacklinkItem[];
  lastUpdatedText?: string | null;
}

const {
  title,
  tags = [],
  headings = [],
  backlinks = [],
  lastUpdatedText = null,
} = Astro.props;

const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 4);
---

<section class="detail-toolbar pixel-card glass-container">
  <div class="detail-left">
    <a href="/notes" class="pixel-button">← 返回</a>
    <h1 class="detail-title">{title}</h1>
  </div>
  <div class="detail-actions">
    <button type="button" class="pixel-button detail-action-btn" title="收藏">⭐</button>
    <button type="button" class="pixel-button detail-action-btn" title="复制链接">🔗</button>
  </div>
</section>

{tags.length > 0 && (
  <div class="detail-tags">
    {tags.map((tag) => (
      <a href={`/tags/${tag}`} class="pixel-badge detail-tag">#{tag}</a>
    ))}
  </div>
)}

<div class="detail-grid">
  <article class="glass-container detail-article prose dark:prose-invert max-w-none">
    <slot />
    {lastUpdatedText && (
      <p class="not-prose detail-updated pixel-digits">{lastUpdatedText}</p>
    )}
  </article>

  <aside class="detail-sidebar">
    {tocHeadings.length > 0 && (
      <section class="glass-container detail-panel detail-panel-outline">
        <div class="detail-panel-head">
          <h3 class="detail-panel-title">📋 大纲</h3>
        </div>
        <div class="detail-outline-scroll">
          <NoteOutlineHost headings={tocHeadings} variant="sidebar" client:load />
        </div>
      </section>
    )}

    {backlinks.length > 0 && (
      <section class="glass-container detail-panel detail-panel-backlinks">
        <h3 class="detail-panel-title">🔗 反向链接</h3>
        <div class="detail-backlinks-scroll">
          <div class="detail-backlinks">
            {backlinks.map((link) => (
              <a href={link.href} class="detail-backlink-link">→ {link.title}</a>
            ))}
          </div>
        </div>
      </section>
    )}
  </aside>
</div>

{tocHeadings.length > 0 && (
  <NoteOutlineHost headings={tocHeadings} variant="mobile" client:load />
)}

<style>
  .detail-toolbar {
    border-width: var(--border-thin);
    padding: 0.85rem 1rem;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
  .detail-left {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }
  .detail-title {
    margin: 0;
    font-size: 1.45rem;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .detail-actions {
    display: inline-flex;
    gap: 0.4rem;
  }
  .detail-action-btn {
    min-width: 44px;
    min-height: 44px;
    padding: 0.42rem 0.6rem;
    touch-action: manipulation;
  }

  .detail-tags {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .detail-tag {
    text-decoration: none;
    color: var(--text-primary);
    background: var(--accent-lavender);
    border-color: var(--border-color);
  }
  :global(.dark) .detail-tag {
    background: #4a355f;
    border-color: #6a4f87;
    color: #f0e8ff;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 1024px) {
    .detail-grid {
      grid-template-columns: minmax(0, 3fr) minmax(250px, 1fr);
      gap: 1.2rem;
      align-items: start;
    }
  }

  .detail-article {
    padding: 1.2rem;
    border: var(--border-thin) solid var(--glass-border);
  }
  .detail-updated {
    margin-top: 1.5rem;
    text-align: right;
    color: var(--text-secondary);
    font-size: 0.75rem;
  }

  .detail-sidebar {
    display: grid;
    gap: 0.8rem;
    align-content: start;
  }
  @media (min-width: 1024px) {
    .detail-sidebar {
      position: sticky;
      top: 86px;
      max-height: calc(100dvh - 96px);
      overflow: visible;
    }
  }
  .detail-panel {
    padding: 0.8rem;
    border: var(--border-thin) solid var(--glass-border);
    min-height: 0;
  }
  .detail-panel-outline {
    display: flex;
    flex-direction: column;
    max-height: min(72vh, calc(100dvh - 140px));
  }
  @media (min-width: 1024px) {
    .detail-panel-outline {
      max-height: min(68vh, calc(100dvh - 180px));
    }
  }
  .detail-panel-backlinks {
    display: flex;
    flex-direction: column;
    max-height: min(36vh, 280px);
  }
  .detail-panel-title {
    margin: 0;
    font-size: 1rem;
    flex-shrink: 0;
  }
  .detail-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.55rem;
    flex-shrink: 0;
  }
  .detail-outline-scroll,
  .detail-backlinks-scroll {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
    margin-right: -0.15rem;
    padding-right: 0.35rem;
    scrollbar-width: thin;
    scrollbar-color: rgb(156 163 175 / 0.55) transparent;
  }
  .detail-outline-scroll::-webkit-scrollbar,
  .detail-backlinks-scroll::-webkit-scrollbar {
    width: 6px;
  }
  .detail-outline-scroll::-webkit-scrollbar-thumb,
  .detail-backlinks-scroll::-webkit-scrollbar-thumb {
    background: rgb(156 163 175 / 0.55);
    border-radius: 999px;
  }
  :global(.dark) .detail-outline-scroll,
  :global(.dark) .detail-backlinks-scroll {
    scrollbar-color: rgb(75 85 99 / 0.7) transparent;
  }
  :global(.dark) .detail-outline-scroll::-webkit-scrollbar-thumb,
  :global(.dark) .detail-backlinks-scroll::-webkit-scrollbar-thumb {
    background: rgb(75 85 99 / 0.7);
  }
  .detail-outline,
  .detail-backlinks {
    display: grid;
    gap: 0.35rem;
  }
  .detail-backlink-link {
    text-decoration: none;
    color: var(--text-secondary);
    font-size: 0.9rem;
    border-radius: var(--radius-small);
    padding: 0.25rem 0.35rem;
    transition: color var(--motion-fast) var(--motion-ease),
      background-color var(--motion-fast) var(--motion-ease);
  }
  .detail-backlink-link:hover {
    color: var(--text-primary);
    background: var(--glass-bg-hover);
  }

  @media (max-width: 1023px) {
    .detail-toolbar {
      padding: 0.72rem 0.85rem;
    }
    .detail-title {
      font-size: 1.15rem;
      white-space: normal;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }
    .detail-panel-outline {
      display: none;
    }
    .detail-sidebar {
      gap: 0.65rem;
    }
    .detail-article {
      padding: 1rem 0.85rem;
    }
    .detail-grid {
      gap: 0.75rem;
    }
  }
</style>
