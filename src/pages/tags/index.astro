---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const notes = await getCollection('notes', ({ data }) => !data.draft);
const tagMap = new Map<string, number>();
for (const note of notes) {
  for (const tag of note.data.tags ?? []) {
    tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
  }
}
const tags = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="标签">
  <section class="subpage-section">
    <h1 class="subpage-title">🏷️ 标签</h1>
    {tags.length === 0 ? (
      <p class="subpage-muted">暂无标签。在笔记 frontmatter 的 <code>tags</code> 字段添加标签。</p>
    ) : (
      <ul class="flex flex-wrap gap-2">
        {tags.map(([tag, count]) => (
          <li>
            <a href={`/tags/${tag}`} class="pixel-badge ui-tag">
              <span>#{tag}</span>
              <span class="ui-tag-count">{count}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
