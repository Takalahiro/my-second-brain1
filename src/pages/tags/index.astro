---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const notes = await getCollection('notes', ({ data }) => !data.draft);
const tagMap = new Map<string, number>();
for (const note of notes) {
  for (const tag of note.data.tags ?? []) {
    tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
  }
}
const tags = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="标签">
  <h1 class="text-3xl font-bold mb-6">🏷️ 标签</h1>
  {tags.length === 0 ? (
    <p class="text-gray-500">暂无标签。在笔记 frontmatter 的 <code>tags</code> 字段添加标签。</p>
  ) : (
    <ul class="flex flex-wrap gap-2">
      {tags.map(([tag, count]) => (
        <li>
          <a href={`/tags/${tag}`} class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-gray-100 dark:bg-gray-800 hover:bg-blue-100 dark:hover:bg-blue-900 transition">
            <span>#{tag}</span>
            <span class="text-xs text-gray-500">{count}</span>
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
