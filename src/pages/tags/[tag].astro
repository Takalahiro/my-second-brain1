---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { noteIdToSlug } from '../../lib/backlinks';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  const tagSet = new Set<string>();
  for (const n of notes) for (const t of n.data.tags ?? []) tagSet.add(t);
  return [...tagSet].map((tag) => ({
    params: { tag },
    props: { tag, notes: notes.filter((n) => (n.data.tags ?? []).includes(tag)) },
  }));
}

const { tag, notes } = Astro.props;
---

<BaseLayout title={`#${tag}`}>
  <h1 class="text-3xl font-bold mb-6">#{tag}</h1>
  <p class="text-gray-500 mb-6">{notes.length} 篇笔记</p>
  <ul class="space-y-3">
    {notes.map((note) => {
      const slug = noteIdToSlug(note.id);
      const title = note.data.title ?? note.id.replace(/\.md$/, '').split('/').pop();
      return (
        <li>
          <a href={`/notes/${slug}`} class="block p-4 rounded-lg border border-gray-200 dark:border-gray-800 hover:border-blue-500 transition">
            <h2 class="font-semibold">{title}</h2>
          </a>
        </li>
      );
    })}
  </ul>
</BaseLayout>
