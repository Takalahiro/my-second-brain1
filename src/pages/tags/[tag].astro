---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { noteIdToSlug } from '../../lib/backlinks';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  const tagSet = new Set<string>();
  for (const n of notes) for (const t of n.data.tags ?? []) tagSet.add(t);
  return [...tagSet].map((tag) => ({
    params: { tag },
    props: { tag, notes: notes.filter((n) => (n.data.tags ?? []).includes(tag)) },
  }));
}

const { tag, notes } = Astro.props;
---

<BaseLayout title={`#${tag}`}>
  <section class="subpage-section">
    <nav class="subpage-breadcrumb">
      <a href="/tags">标签</a>
      <span>/</span>
      <span>#{tag}</span>
    </nav>
    <h1 class="subpage-title">#{tag}</h1>
    <p class="subpage-muted" style="margin-bottom: var(--space-4);">{notes.length} 篇笔记</p>
    <ul class="subpage-stack-md" style="list-style: none; margin: 0; padding: 0;">
      {notes.map((note) => {
        const slug = noteIdToSlug(note.id);
        const title = note.data.title ?? note.id.replace(/\.md$/, '').split('/').pop();
        return (
          <li>
            <a href={`/notes/${slug}`} class="ui-list-card">
              <h2 class="ui-list-card-title">{title}</h2>
            </a>
          </li>
        );
      })}
    </ul>
  </section>
</BaseLayout>
