---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildFolderTree, countNotes } from '../lib/folder-tree';

const notes = await getCollection('notes', ({ data }) => !data.draft);
const tree = buildFolderTree(notes);
const total = countNotes(tree);
const topFolders = tree.children;

// 统计标签总数
const tagSet = new Set<string>();
for (const n of notes) for (const t of n.data.tags ?? []) tagSet.add(t);
---

<BaseLayout title="My Second Brain">
  <section class="hero">
    <h1 class="hero-title">🧠 My Second Brain</h1>
    <p class="hero-sub">
      一个 Obsidian 风格的个人知识库 · 支持 Wiki Link、反向链接、LaTeX、Mermaid、暗黑模式
    </p>

    <div class="hero-stats">
      <div class="stat">
        <div class="stat-num">{total}</div>
        <div class="stat-label">笔记</div>
      </div>
      <div class="stat">
        <div class="stat-num">{topFolders.length}</div>
        <div class="stat-label">学科</div>
      </div>
      <div class="stat">
        <div class="stat-num">{tagSet.size}</div>
        <div class="stat-label">标签</div>
      </div>
    </div>

    <div class="hero-cta">
      <a href="/notes" class="cta primary">📚 浏览笔记</a>
      <a href="/tags" class="cta">🏷️ 标签</a>
    </div>
  </section>

  <section class="cards placeholder-section">
    <h2 class="section-title">📁 学科分类</h2>
    <p class="placeholder-text">（暂未开放，后续在此展示各学科入口）</p>
  </section>

  <section class="cards placeholder-section">
    <h2 class="section-title">🕒 最近更新</h2>
    <p class="placeholder-text">（暂未开放，后续在此展示最近编辑的笔记）</p>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid rgb(229 231 235);
    margin-bottom: 2.5rem;
  }
  :global(.dark) .hero {
    border-bottom-color: rgb(31 41 55);
  }
  .hero-title {
    font-size: 3rem;
    font-weight: 800;
    margin: 0 0 0.75rem;
    background: linear-gradient(135deg, rgb(59 130 246), rgb(139 92 246));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-sub {
    font-size: 1.125rem;
    color: rgb(75 85 99);
    margin: 0 auto 2rem;
    max-width: 38rem;
    line-height: 1.6;
  }
  :global(.dark) .hero-sub {
    color: rgb(156 163 175);
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    margin: 0 0 2rem;
  }
  .stat {
    text-align: center;
  }
  .stat-num {
    font-size: 2rem;
    font-weight: 700;
    color: rgb(37 99 235);
  }
  :global(.dark) .stat-num {
    color: rgb(96 165 250);
  }
  .stat-label {
    font-size: 0.875rem;
    color: rgb(107 114 128);
    margin-top: 2px;
  }

  .hero-cta {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .cta {
    display: inline-block;
    padding: 0.625rem 1.25rem;
    border-radius: 0.5rem;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid rgb(229 231 235);
    color: rgb(31 41 55);
    background: white;
    transition: transform 0.12s, box-shadow 0.12s;
  }
  .cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 10px -2px rgb(0 0 0 / 0.1);
  }
  :global(.dark) .cta {
    background: rgb(17 24 39);
    border-color: rgb(55 65 81);
    color: rgb(229 231 235);
  }
  .cta.primary {
    background: rgb(37 99 235);
    border-color: rgb(37 99 235);
    color: white;
  }
  .cta.primary:hover {
    background: rgb(29 78 216);
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 1rem;
  }
  .cards {
    margin-bottom: 3rem;
  }

  .placeholder-section {
    padding: 1.25rem 1.5rem;
    border-radius: 0.625rem;
    border: 1px dashed rgb(209 213 219);
    background: rgb(249 250 251);
  }
  :global(.dark) .placeholder-section {
    border-color: rgb(55 65 81);
    background: rgb(17 24 39 / 0.5);
  }
  .placeholder-text {
    margin: 0;
    font-size: 0.9375rem;
    color: rgb(107 114 128);
    font-style: italic;
  }
  :global(.dark) .placeholder-text {
    color: rgb(107 114 128);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.875rem;
  }
  .card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    border-radius: 0.625rem;
    border: 1px solid rgb(229 231 235);
    background: white;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.12s, transform 0.12s, box-shadow 0.12s;
  }
  .card:hover {
    border-color: rgb(59 130 246);
    transform: translateY(-2px);
    box-shadow: 0 6px 16px -4px rgb(0 0 0 / 0.1);
  }
  :global(.dark) .card {
    background: rgb(17 24 39);
    border-color: rgb(55 65 81);
  }
  :global(.dark) .card:hover {
    border-color: rgb(96 165 250);
  }
  .card-icon {
    font-size: 1.75rem;
    flex: 0 0 auto;
  }
  .card-body {
    flex: 1;
    min-width: 0;
  }
  .card-title {
    font-weight: 600;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .card-meta {
    font-size: 0.8125rem;
    color: rgb(107 114 128);
    margin-top: 2px;
  }

  .recent-list {
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
  }
  .recent-link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.625rem 0.75rem;
    border-radius: 0.375rem;
    color: inherit;
    text-decoration: none;
    transition: background 0.12s;
  }
  .recent-link:hover {
    background: rgb(243 244 246);
  }
  :global(.dark) .recent-link:hover {
    background: rgb(31 41 55);
  }
  .recent-title {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-weight: 500;
  }
  .recent-date {
    flex: 0 0 auto;
    font-size: 0.75rem;
    color: rgb(156 163 175);
  }

  .see-all {
    display: inline-block;
    font-size: 0.875rem;
    color: rgb(37 99 235);
    text-decoration: none;
  }
  .see-all:hover {
    text-decoration: underline;
  }
  :global(.dark) .see-all {
    color: rgb(96 165 250);
  }
</style>
