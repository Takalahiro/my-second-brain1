---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { noteIdToSlug } from '../../lib/backlinks';
import { getNoteLastUpdated, formatLastUpdated } from '../../lib/git-mtime';
import PixelIcon from '../../components/PixelIcon.astro';

function decodeFolderPath(raw: string) {
  return raw
    .split('/')
    .filter(Boolean)
    .join('/');
}

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  const folderSet = new Set<string>();

  for (const note of notes) {
    const parts = note.id.split('/');
    if (parts.length <= 2) continue;
    folderSet.add(parts.slice(0, -1).join('/'));
  }

  return [...folderSet].map((folderPath) => ({
    params: { folder: folderPath },
    props: {
      folderPath,
      notes: notes.filter((n) => n.id.startsWith(folderPath + '/')),
    },
  }));
}

const { folderPath, notes } = Astro.props as { folderPath: string; notes: any[] };
const decodedPath = decodeFolderPath(folderPath);

notes.sort((a, b) => {
  const da = a.data.date?.getTime() ?? 0;
  const db = b.data.date?.getTime() ?? 0;
  return db - da;
});
---

<BaseLayout title={decodedPath}>
  <nav class="text-sm text-gray-500 mb-4">
    <a href="/notes" class="hover:underline">笔记</a>
    <span class="mx-2">/</span>
    <span class="inline-flex items-center gap-1"><PixelIcon name="folder" size={14} /> {decodedPath}</span>
  </nav>

  <h1 class="text-3xl font-bold mb-3 inline-flex items-center gap-2"><PixelIcon name="folder" size={24} /> {decodedPath}</h1>
  <p class="text-gray-500 mb-6">{notes.length} 篇笔记</p>

  <ul class="space-y-3">
    {notes.map((note) => {
      const slug = noteIdToSlug(note.id);
      const title = note.data.title ?? note.id.replace(/\.md$/, '').split('/').pop();
      const updated = getNoteLastUpdated(note.id);
      const updatedText = updated ? formatLastUpdated(updated) : null;
      return (
        <li>
          <a href={`/notes/${slug}`} class="block p-4 rounded-lg border border-gray-200 dark:border-gray-800 hover:border-blue-500 transition">
            <div class="flex items-baseline justify-between gap-4">
              <h2 class="font-semibold">{title}</h2>
              {updatedText && (
                <time class="text-xs text-gray-500 shrink-0 pixel-digits" datetime={updated.toISOString()}>
                  更新 {updatedText}
                </time>
              )}
            </div>
            {note.data.description && (
              <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{note.data.description}</p>
            )}
          </a>
        </li>
      );
    })}
  </ul>
</BaseLayout>
