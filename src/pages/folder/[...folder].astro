---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { noteIdToSlug } from '../../lib/backlinks';
import { getNoteLastUpdated, formatLastUpdated } from '../../lib/git-mtime';
import PixelIcon from '../../components/PixelIcon.astro';

function decodeFolderPath(raw: string) {
  return raw
    .split('/')
    .filter(Boolean)
    .join('/');
}

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  const folderSet = new Set<string>();

  for (const note of notes) {
    const parts = note.id.split('/');
    if (parts.length <= 2) continue;
    folderSet.add(parts.slice(0, -1).join('/'));
  }

  return [...folderSet].map((folderPath) => ({
    params: { folder: folderPath },
    props: {
      folderPath,
      notes: notes.filter((n) => n.id.startsWith(folderPath + '/')),
    },
  }));
}

const { folderPath, notes } = Astro.props as { folderPath: string; notes: any[] };
const decodedPath = decodeFolderPath(folderPath);

notes.sort((a, b) => {
  const da = a.data.date?.getTime() ?? 0;
  const db = b.data.date?.getTime() ?? 0;
  return db - da;
});
---

<BaseLayout title={decodedPath}>
  <section class="subpage-section">
    <nav class="subpage-breadcrumb">
      <a href="/notes">笔记</a>
      <span>/</span>
      <span class="inline-flex items-center gap-1"><PixelIcon name="folder" size={14} /> {decodedPath}</span>
    </nav>

    <h1 class="subpage-title inline-flex items-center gap-2">
      <PixelIcon name="folder" size={24} /> {decodedPath}
    </h1>
    <p class="subpage-muted" style="margin-bottom: var(--space-4);">{notes.length} 篇笔记</p>

    <ul class="subpage-stack-md" style="list-style: none; margin: 0; padding: 0;">
      {notes.map((note) => {
        const slug = noteIdToSlug(note.id);
        const title = note.data.title ?? note.id.replace(/\.md$/, '').split('/').pop();
        const updated = getNoteLastUpdated(note.id);
        const updatedText = updated ? formatLastUpdated(updated) : null;
        return (
          <li>
            <a href={`/notes/${slug}`} class="ui-list-card">
              <div class="flex items-baseline justify-between gap-4">
                <h2 class="ui-list-card-title">{title}</h2>
                {updatedText && (
                  <time class="subpage-muted pixel-digits shrink-0" style="font-size: var(--text-xs);" datetime={updated.toISOString()}>
                    更新 {updatedText}
                  </time>
                )}
              </div>
              {note.data.description && (
                <p class="ui-list-card-desc">{note.data.description}</p>
              )}
            </a>
          </li>
        );
      })}
    </ul>
  </section>
</BaseLayout>
