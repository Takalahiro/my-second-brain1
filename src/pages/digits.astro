---
import ToolLayout from '../layouts/ToolLayout.astro';
import DigitRecognizer from '../lib/components/DigitRecognizer/DigitRecognizer.svelte';
---

<ToolLayout title="手写数字 · CNN 可视化 · My Second Brain" description="MNIST 手写识别与卷积神经网络特征图逐步可视化">
  <DigitRecognizer client:only="svelte">
    <div class="digits-fallback" slot="fallback">
      <div class="digits-fallback-inner">
        <p class="digits-fallback-title">手写数字 · CNN 可视化</p>
        <p class="digits-fallback-hint">正在加载 TensorFlow.js 与界面组件…</p>
      </div>
    </div>
  </DigitRecognizer>
</ToolLayout>

<style>
  .digits-fallback {
    min-height: calc(100vh - 88px);
    display: grid;
    place-items: center;
    padding: 2rem;
    color: var(--text-secondary);
  }
  .digits-fallback-inner {
    text-align: center;
    padding: 2rem 2.5rem;
    border-radius: 16px;
    border: 1px dashed rgb(180 140 255 / 0.25);
    background: rgb(180 140 255 / 0.05);
  }
  .digits-fallback-title {
    margin: 0 0 8px;
    font-size: 1.1rem;
    color: var(--text-primary);
  }
  .digits-fallback-hint {
    margin: 0;
    font-size: 0.85rem;
  }
</style>
