---
import ToolLayout from '../layouts/ToolLayout.astro';
import NeuralLab from '../lib/components/NeuralLab/NeuralLab.svelte';
import { NEURAL_LAB } from '../lib/neural-lab-meta';
---

<ToolLayout
  title="{NEURAL_LAB.title} · My Second Brain"
  description={NEURAL_LAB.description}
  mathJax={true}
>
  <NeuralLab client:only="svelte">
    <div class="digits-fallback" slot="fallback">
      <div class="digits-fallback-inner">
        <p class="digits-fallback-title">{NEURAL_LAB.title}</p>
        <p class="digits-fallback-hint">正在加载实验室模块…</p>
      </div>
    </div>
  </NeuralLab>
</ToolLayout>

<style>
  .digits-fallback {
    min-height: calc(100vh - 88px);
    display: grid;
    place-items: center;
    padding: 2rem;
    color: var(--text-secondary);
  }
  .digits-fallback-inner {
    text-align: center;
    padding: 2rem 2.5rem;
    border-radius: 16px;
    border: 1px dashed rgb(180 140 255 / 0.25);
    background: rgb(180 140 255 / 0.05);
  }
  .digits-fallback-title {
    margin: 0 0 8px;
    font-size: 1.1rem;
    color: var(--text-primary);
  }
  .digits-fallback-hint {
    margin: 0;
    font-size: 0.85rem;
  }
</style>
