---
import ToolLayout from '../layouts/ToolLayout.astro';
import NeuralLab from '../lib/components/NeuralLab/NeuralLab.svelte';
import { NEURAL_LAB } from '../lib/neural-lab-meta';
---

<ToolLayout
  title="{NEURAL_LAB.title} · My Second Brain"
  description={NEURAL_LAB.description}
  mathJax={true}
>
  <NeuralLab client:only="svelte">
    <div class="digits-fallback" slot="fallback">
      <div class="digits-fallback-inner">
        <p class="digits-fallback-title">{NEURAL_LAB.title}</p>
        <p class="digits-fallback-hint">正在加载实验室模块…</p>
      </div>
    </div>
  </NeuralLab>
</ToolLayout>

<style>
  .digits-fallback {
    min-height: calc(100dvh - var(--site-nav-offset, 88px));
    display: grid;
    place-items: center;
    padding: var(--space-5);
    color: var(--text-muted, var(--text-secondary));
  }
  .digits-fallback-inner {
    text-align: center;
    padding: var(--space-5) var(--space-6);
    border-radius: var(--radius-card);
    border: 1px dashed color-mix(in srgb, var(--accent-out, var(--ui-accent)) 25%, transparent);
    background: color-mix(in srgb, var(--accent-out, var(--ui-accent)) 5%, transparent);
    box-shadow: var(--shadow-sm);
  }
  .digits-fallback-title {
    margin: 0 0 var(--space-2);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--text, var(--text-primary));
  }
  .digits-fallback-hint {
    margin: 0;
    font-size: var(--text-sm);
  }
</style>
