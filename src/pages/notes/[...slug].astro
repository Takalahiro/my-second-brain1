---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NoteDetailLayout from '../../components/Notes/NoteDetailLayout.astro';
import { getBacklinks, noteIdToSlug } from '../../lib/backlinks';
import { getNoteLastUpdated, formatLastUpdated } from '../../lib/git-mtime';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  return notes.map((note) => ({
    params: { slug: noteIdToSlug(note.id) },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content, headings } = await render(note);
const backlinks = await getBacklinks(noteIdToSlug(note.id));

const title = note.data.title ?? note.id.replace(/\.md$/, '').split('/').pop();
const lastUpdated = getNoteLastUpdated((note as any).filePath ?? note.id);
const outline = headings
  .filter((h) => h.depth >= 2 && h.depth <= 4)
  .map((h) => ({ id: h.slug, title: h.text, level: h.depth }));
const backlinkItems = backlinks.map((b) => ({
  title: b.data.title ?? b.id.replace(/\.md$/, '').split('/').pop() ?? b.id,
  href: `/notes/${noteIdToSlug(b.id)}`,
}));
---

<BaseLayout title={title} description={note.data.description}>
  <NoteDetailLayout
    title={title}
    tags={note.data.tags ?? []}
    outline={outline}
    backlinks={backlinkItems}
    lastUpdatedText={lastUpdated ? `最后更新 · ${formatLastUpdated(lastUpdated)}` : null}
  >
    <Content />
  </NoteDetailLayout>
</BaseLayout>
