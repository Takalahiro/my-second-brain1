---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NotesExplorer from '../../components/Notes/NotesExplorer.svelte';
import { buildFolderTree, countNotes } from '../../lib/folder-tree';
import { maxMtimeForFolder, enrichFolderTreeMtime } from '../../lib/note-mtime-helpers';
import { DEFAULT_FOLDER_ICON, folderEmojiToIcon, type PixelIconName } from '../../lib/pixel-icons';
import vaultSyncMeta from '../../lib/vault-sync-meta.json';

const notes = await getCollection('notes', ({ data }) => !data.draft);
const tree = buildFolderTree(notes);
enrichFolderTreeMtime(tree);
const allNoteIds = notes.map((n) => n.id);

const topFolders = tree.children;

function guessFolderIcon(name: string): PixelIconName {
  return folderEmojiToIcon(name);
}

function encodeFolderPath(path: string) {
  return path
    .split('/')
    .filter(Boolean)
    .map((seg) => encodeURIComponent(seg))
    .join('/');
}

function flattenFolders(node: (typeof topFolders)[number], depth = 0): Array<{
  id: string;
  title: string;
  icon: PixelIconName;
  count: number;
  lastUpdated: string;
  href: string;
  depth: number;
}> {
  const acc: Array<{
    id: string;
    title: string;
    icon: PixelIconName;
    count: number;
    lastUpdated: string;
    href: string;
    depth: number;
  }> = [];

  for (const child of node.children) {
    acc.push({
      id: `folder:${child.path}`,
      title: child.name,
      icon: DEFAULT_FOLDER_ICON,
      count: countNotes(child),
      lastUpdated: maxMtimeForFolder(child.path, allNoteIds),
      href: `/folder/${encodeFolderPath(child.path)}`,
      depth,
    });
    acc.push(...flattenFolders(child as (typeof topFolders)[number], depth + 1));
  }
  return acc;
}

const categories = topFolders.map((folder) => ({
  title: folder.name,
  folderIcon: guessFolderIcon(folder.name),
  folders: flattenFolders(folder),
  // 主列表页只展示目录卡片；笔记内容在目录页内展示
  notes: [],
}));
---

<BaseLayout title="笔记 · My Second Brain" wide>
  <!--
    client:only：禁止 SSR；
    与 BaseLayout 的预水合脚本（写 <html data-notes-mode>）配合，
    可保证首屏渲染就用对的折叠模式，避免线上反复闪烁。
  -->
  <NotesExplorer
    categories={categories}
    tree={tree}
    syncMeta={vaultSyncMeta}
    client:only="svelte"
  />
</BaseLayout>
